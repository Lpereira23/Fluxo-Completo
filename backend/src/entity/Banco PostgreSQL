version: '3'

services:

 postgres:
  image: postgres:15

  environment:
   POSTGRES_DB: agenda

   POSTGRES_USER: postgres

   POSTGRES_PASSWORD: postgres

  ports:
   - "5432:5432"

 backend:

  build: ./backend

  ports:
   - "8080:8080"

 frontend:

  build: ./frontend

  ports:
   - "3000:3000"